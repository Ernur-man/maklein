# === Публичные (клиент) ===
# Google Sheets — только таблица КОНТЕНТА (Viewer, не заявки)
VITE_GOOGLE_SHEET_ID=your_content_spreadsheet_id
VITE_SHEET_CONFIG=config
VITE_SHEET_HOW_IT_WORKS=how_it_works
VITE_SHEET_TEACHERS=teachers
VITE_SHEET_REVIEWS=reviews
VITE_SHEET_PRICING=pricing

# Cloudflare Turnstile — публичный site key (виден в бандле — это норма)
VITE_TURNSTILE_SITE_KEY=your_turnstile_site_key

# Дополнительные домены для изображений (через запятую)
# VITE_ALLOWED_IMAGE_HOSTS=cdn.example.com,storage.example.com

# === Серверные (НЕ VITE_, только на Vercel/Netlify и в .env для npm run dev) ===
# URL Sheet Monkey — таблица ЗАЯВОК (приватная, не в фронтенде)
SHEET_MONKEY_URL=https://api.sheetmonkey.io/form/your-form-id

# Cloudflare Turnstile secret — только на сервере (из dashboard Cloudflare)
TURNSTILE_SECRET=your_turnstile_secret_key

# ⚠️ Имена колонок в Google Sheet должны совпадать с полями формы:
# Name | Email | Phone | Plan | Message | Submitted At
